// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // ВАЖНО: для Neon/Vercel используйте "postgresql".
  // Для локальной разработки с файлом БД — "sqlite".
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Сырые собранные события по маркерам (аналог raw_events в спецификации).
/// Хранятся 30 дней, затем можно чистить. Источник: Google News RSS + NewsAPI fallback.
model RawEvent {
  id          String   @id @default(cuid())
  markerId    String
  eventDate   DateTime
  sourceUrl   String
  sourceName  String
  rawText     String
  collectedAt DateTime @default(now())

  @@index([markerId, eventDate])
  @@index([sourceUrl])
}

/// Оценки ИИ по каждому маркеру за дату расчёта (аналог marker_scores).
/// ШКАЛА: probability ∈ [-100, +100], где:
///   -100 = максимальная эскалация (война, ядерные угрозы, мобилизация)
///      0 = стагнация / замороженный конфликт
///   +100 = гарантированный мир (инвестиции, договоры, демилитаризация)
/// trend: UP = движение к миру, DOWN = движение к войне, FLAT = без изменений
model MarkerScore {
  id           String   @id @default(cuid())
  calcDate     DateTime
  markerId     String
  probability  Int      // -100 (max escalation) .. +100 (durable peace), 0 = stalemate
  trend        String   // UP | DOWN | FLAT
  confidence   String   // HIGH | MEDIUM | LOW
  rationaleEn  String
  rationaleRu  String?
  // Храним как JSON-строку (совместимо с SQLite и PostgreSQL)
  keyFactsJson String
  weight       Int      // Вес маркера на момент расчёта (1..12)
  createdAt    DateTime @default(now())

  @@unique([calcDate, markerId])
  @@index([calcDate])
}

/// Отслеживание позиций конкретных институциональных игроков (инвесторов, страховщиков,
/// законодателей) по финансовым/юридическим маркерам во времени — чтобы отличать
/// "подтверждение прежней позиции" от "пересмотра вниз / отзыва" (например, BlackRock
/// снизил заявленную сумму инвестиций с $100 млрд до $30 млрд). Используется как
/// контекст для LLM при анализе следующего дня по тому же маркеру.
model EntityCommitment {
  id           String   @id @default(cuid())
  markerId     String
  entityName   String   // "BlackRock", "MIGA", "EBRD"... — как выдала модель
  stance       String   // NEW | REAFFIRMED | INCREASED | REDUCED | WITHDRAWN
  claimSummary String   // краткое описание на английском
  claimDate    DateTime // дата события/заявления (не дата расчёта)
  sourceUrl    String
  calcDate     DateTime // дата прогона, которым это было зафиксировано
  createdAt    DateTime @default(now())

  // Один и тот же источник по одной и той же сущности в рамках маркера не дублируется —
  // повторный проход по той же статье обновляет запись, а не создаёт копию.
  @@unique([markerId, sourceUrl, entityName])
  @@index([markerId, entityName, claimDate])
}

/// Итоговая агрегированная оценка за дату (аналог aggregates).
/// ШКАЛА: totalProbability ∈ [-100, +100] — взвешенное среднее по всем маркерам.
/// Интерпретация:
///   -80..-100: война неизбежна
///   -40..-79:  эскалация нарастает
///   -20..+19:  стагнация / замороженный конфликт
///   +20..+59:  мирная тенденция усиливается
///   +60..+100: мир становится вероятным
model Aggregate {
  calcDate         DateTime @id
  totalProbability Int      // -100 (war) .. +100 (peace), 0 = deadlock
  summaryEn        String
  summaryRu        String?
  markerCount      Int      // Сколько маркеров участвовало в расчёте (всего 24)
  createdAt        DateTime @default(now())
}
